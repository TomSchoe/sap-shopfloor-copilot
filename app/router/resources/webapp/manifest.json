{
  "_version": "1.59.0",
  "sap.app": {
    "id": "shopfloor.copilot",
    "type": "application",
    "title": "Shopfloor Copilot",
    "i18n": "i18n/i18n.properties"
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": { "desktop": true, "tablet": true, "phone": true }
  },
  "sap.ui5": {
    "rootView": {
      "viewName": "shopfloor.copilot.view.Main",
      "type": "XML",
      "id": "main"
    },
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": { "sap.m": {}, "sap.ui.core": {}, "sap.f": {} }
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "shopfloor.copilot.i18n.i18n",
          "supportedLocales": ["de", "en"],
          "fallbackLocale": "de"
        }
      }
    }
  }
}
