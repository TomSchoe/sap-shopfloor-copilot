{
  "welcomeFile": "/webapp/index.html",
  "authenticationMethod": "route",
  "logout": {
    "logoutEndpoint": "/logout",
    "logoutPage": "/logout.html"
  },
  "routes": [
    {
      "source": "^/logout.html$",
      "target": "logout.html",
      "localDir": "resources/webapp",
      "authenticationType": "none"
    },
    {
      "source": "^/webapp/(.*)$",
      "target": "$1",
      "localDir": "resources/webapp",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^/(.*)$",
      "target": "$1",
      "destination": "srv-api",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    }
  ]
}
